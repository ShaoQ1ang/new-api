    "/api/skill-hub/skills/{id}/download": {
      "get": {
        "summary": "下载技能包",
        "deprecated": false,
        "description": "🔓 无需鉴权；成功时 302 跳转到技能包源地址或签名下载地址",
        "tags": [
          "技能广场"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "技能 ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "失败时返回统一 JSON 错误结构",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "302": {
            "description": "跳转到技能包下载地址",
            "headers": {
              "Location": {
                "description": "技能包下载地址",
                "schema": {
                  "type": "string",
                  "format": "uri"
                }
              }
            }
          }
        }
      }
    },
