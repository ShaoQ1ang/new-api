      "SkillHubDirectUploadInitRequest": {
        "type": "object",
        "description": "初始化 Skill Hub OSS 直传的请求体",
        "required": [
          "kind",
          "skillId",
          "fileName",
          "size"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "zip",
              "icon"
            ],
            "description": "上传类型：zip 表示技能压缩包，icon 表示技能图标",
            "example": "zip"
          },
          "skillId": {
            "type": "string",
            "description": "技能 ID；用于生成 OSS Object Key 路径",
            "example": "demo.skill"
          },
          "version": {
            "type": "string",
            "description": "技能版本；zip 上传时用于生成 OSS Object Key，icon 上传可为空",
            "example": "1.0.0"
          },
          "fileName": {
            "type": "string",
            "description": "本地选择的原始文件名，仅用于识别扩展名和生成对象名",
            "example": "demo-skill.zip"
          },
          "size": {
            "type": "integer",
            "format": "int64",
            "description": "文件大小，单位 byte；zip 最大 50MB，icon 最大 1MB",
            "example": 1048576
          }
        }
      },
      "SkillHubDirectUploadInitResult": {
        "type": "object",
        "description": "Skill Hub OSS 直传初始化结果",
        "required": [
          "kind",
          "fileName",
          "object",
          "size",
          "contentType",
          "uploadUrl",
          "uploadMethod",
          "uploadHeaders",
          "uploadTicket",
          "expiresAt"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "zip",
              "icon"
            ],
            "description": "上传类型",
            "example": "zip"
          },
          "fileName": {
            "type": "string",
            "description": "规范化后的文件名",
            "example": "demo-skill.zip"
          },
          "object": {
            "type": "string",
            "description": "_tmp 临时 OSS Object Key；complete 成功后作为 source.ref 或图标对象来源使用，保存 Skill 成功后后端会转正为正式 Object Key",
            "example": "skill-hub/skills/_tmp/packages/demo.skill/8f3c6e9d2a1b4c5d9e0f123456789abc/demo-skill.zip"
          },
          "size": {
            "type": "integer",
            "format": "int64",
            "description": "文件大小，单位 byte",
            "example": 1048576
          },
          "contentType": {
            "type": "string",
            "description": "PUT 到 OSS 时必须使用的 Content-Type",
            "example": "application/zip"
          },
          "uploadUrl": {
            "type": "string",
            "format": "uri",
            "description": "短时 OSS PUT signed URL；浏览器直接向该地址上传文件",
            "example": "https://bucket.oss-cn-hangzhou.aliyuncs.com/skill-hub/skills/..."
          },
          "uploadMethod": {
            "type": "string",
            "enum": [
              "PUT"
            ],
            "description": "上传 HTTP 方法，固定为 PUT",
            "example": "PUT"
          },
          "uploadHeaders": {
            "type": "object",
            "description": "PUT 到 OSS 时必须携带的请求头",
            "additionalProperties": {
              "type": "string"
            },
            "example": {
              "Content-Type": "application/zip"
            }
          },
          "uploadTicket": {
            "type": "string",
            "description": "短时上传票据；PUT 完成后传给 complete，未保存或替换草稿时可传给 discard 清理 OSS 对象",
            "example": "base64url-payload.base64url-signature"
          },
          "expiresAt": {
            "type": "integer",
            "format": "int64",
            "description": "signed URL 和上传票据过期时间，Unix 秒",
            "example": 1780000000
          }
        }
      },
      "SkillHubDirectUploadCompleteRequest": {
        "type": "object",
        "description": "完成或丢弃 Skill Hub OSS 直传的请求体",
        "required": [
          "uploadTicket"
        ],
        "properties": {
          "uploadTicket": {
            "type": "string",
            "description": "初始化接口返回的短时上传票据",
            "example": "base64url-payload.base64url-signature"
          }
        }
      },
      "SkillHubDirectUploadInitApiResponse": {
        "type": "object",
        "description": "Skill Hub OSS 直传初始化响应",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/SkillHubDirectUploadInitResult"
          }
        }
      }
    },
