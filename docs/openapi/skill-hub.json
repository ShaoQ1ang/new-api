    "/api/skill-hub/skills/{id}/download": {
      "get": {
        "summary": "下载技能包",
        "deprecated": false,
        "description": "🔓 无需鉴权；成功时 302 跳转到技能包源地址或签名下载地址",
        "tags": ["技能广场"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "技能 ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "失败时返回统一 JSON 错误结构",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "302": {
            "description": "跳转到技能包下载地址",
            "headers": {
              "Location": {
                "description": "技能包下载地址",
                "schema": {
                  "type": "string",
                  "format": "uri"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/skill-hub/upload": {
      "post": {
        "summary": "上传技能包",
        "deprecated": false,
        "description": "👨‍💼 需要管理员权限（Admin）；仅支持 zip 文件，最大 50MB",
        "tags": ["技能广场管理"],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file", "skill_id"],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "zip 技能包文件"
                  },
                  "skill_id": {
                    "type": "string",
                    "description": "技能 ID"
                  },
                  "version": {
                    "type": "string",
                    "description": "技能版本"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkillHubUploadApiResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "SessionAuth": [],
            "NewApiUser": []
