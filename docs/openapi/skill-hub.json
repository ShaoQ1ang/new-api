{
  "openapi": "3.0.1",
  "info": {
    "title": "技能广场接口",
    "description": "Skill Hub 技能广场公开浏览与管理员维护接口。",
    "version": "1.0.0"
  },
  "tags": [
    {
      "name": "技能广场",
      "description": "公开浏览与下载技能"
    },
    {
      "name": "技能广场管理",
      "description": "管理员维护技能、标签、上传资源与发布状态"
    }
  ],
  "paths": {
    "/api/skill-hub/skills": {
      "get": {
        "summary": "获取技能广场技能列表",
        "deprecated": false,
        "description": "🔓 无需鉴权；仅返回已发布技能",
        "tags": [
          "技能广场"
        ],
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "description": "搜索关键字，匹配技能 ID、名称、描述或标签；最多 128 个字符，%、_、! 按普通字符处理",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "recommended",
            "in": "query",
            "description": "是否仅返回推荐技能；true、1、yes 表示仅推荐",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "p",
            "in": "query",
            "description": "页码",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "每页数量",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkillHubListApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/skill-hub/skills/recommend": {
      "get": {
        "summary": "随机获取推荐技能",
        "deprecated": false,
        "description": "🔓 无需鉴权；从已发布且标记推荐的技能中随机返回一组，用于前台“换一换”",
        "tags": [
          "技能广场"
        ],
        "parameters": [
          {
            "name": "page_size",
            "in": "query",
            "description": "返回数量，默认 4，最大 20",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 4,
              "maximum": 20,
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkillHubListApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/skill-hub/tags": {
      "get": {
        "summary": "获取技能广场标签列表",
        "deprecated": false,
        "description": "🔓 无需鉴权；仅返回已发布技能正在使用的标签。公开读取不会触发标签同步写入",
        "tags": [
          "技能广场"
        ],
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "description": "搜索关键字，匹配标签名称；最多 128 个字符，%、_、! 按普通字符处理",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "p",
            "in": "query",
            "description": "页码",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "每页数量，最大 100",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkillHubTagListApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/skill-hub/tags/skills": {
      "get": {
        "summary": "按标签获取技能广场技能列表",
        "deprecated": false,
        "description": "🔓 无需鉴权；按一个或多个标签 ID 返回已发布技能；未传 tag_ids 时返回全部已发布技能",
        "tags": [
          "技能广场"
        ],
        "parameters": [
          {
            "name": "tag_ids",
            "in": "query",
            "description": "标签 ID，多个 ID 使用英文逗号分隔，例如 1,2；不传或传空字符串时返回全部；最多 50 个 ID",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "description": "可选搜索关键字，匹配技能 ID、名称、描述或标签；最多 128 个字符，%、_、! 按普通字符处理",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "recommended",
            "in": "query",
            "description": "是否仅返回推荐技能；true、1、yes 表示仅推荐",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "p",
            "in": "query",
            "description": "页码",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "每页数量",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkillHubListApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/skill-hub/skills/{id}": {
      "get": {
        "summary": "获取技能广场技能详情",
        "deprecated": false,
        "description": "🔓 无需鉴权；仅可获取已发布技能",
        "tags": [
          "技能广场"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "技能 ID",
